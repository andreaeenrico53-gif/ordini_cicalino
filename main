export default async function handler(req, res) {
    if (req.method !== 'POST') return res.status(405).send('Method Not Allowed');

    const { message, callback_query } = req.body;
    const SB_URL = "https://ehyznszspoobksladnwy.supabase.co";
    const SB_KEY = "sb_publishable_wxt4OsEMsYKj6ZyAtFHyLQ_ENfylzJH"; 
    const token = process.env.TELEGRAM_TOKEN;

    try {
        // --- 1. GESTIONE CLICK BOTTONI (Azione 'S' = Scegli) ---
        if (callback_query) {
            const chatId = callback_query.message.chat.id;
            const data = callback_query.data.split('|'); 

            if (data[0] === 'S') {
                // Recupera il nome dal testo del bottone cliccato
                const bottone = callback_query.message.reply_markup.inline_keyboard
                    .flat()
                    .find(b => b.callback_data === callback_query.data);
                
                const nomeProdotto = bottone ? bottone.text : "Prodotto";

                await inviaTelegram(chatId, `Hai scelto: <b>${nomeProdotto}</b>\n\nScrivi quante unità vuoi AGGIUNGERE:`, token, { force_reply: true });
            }
            return res.status(200).json({ ok: true });
        }

        // --- 2. GESTIONE MESSAGGI DI TESTO ---
        if (message && message.text) {
            const chatId = message.chat.id;
            const text = message.text.trim();

            // COMANDO: /aggiungi (Mostra bottoni)
            if (text.startsWith('/aggiungi')) {
                const response = await fetch(`${SB_URL}/rest/v1/prodotti?select=id,nome&order=nome.asc`, {
                    headers: { "apikey": SB_KEY, "Authorization": `Bearer ${SB_KEY}` }
                });

                if (!response.ok) {
                    await inviaTelegram(chatId, "❌ Errore connessione Database.", token);
                    return res.status(200).send('OK');
                }

                const prodotti = await response.json();
                const tastiera = [];
