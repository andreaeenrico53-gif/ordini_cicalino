#include <WiFi.h>
#include <WiFiClientSecure.h>
#include <UniversalTelegramBot.h>
#include <ArduinoJson.h>

// --- CONFIGURAZIONE ---
const char* ssid = "NOME_TUA_RETE";
const char* password = "PASSWORD_WIFI";
const char* botToken = "IL_TUO_TOKEN_BOT";
const char* chatID = "ID_DEL_GRUPPO_CAMERIERI"; // Può essere l'ID del gruppo o il tuo ID privato

const int pinTasto = 4; // Pin del tasto ordine pronto

WiFiClientSecure client;
UniversalTelegramBot bot(botToken, client);

void setup() {
  Serial.begin(115200);
  pinMode(pinTasto, INPUT_PULLUP);

  WiFi.begin(ssid, password);
  client.setInsecure(); // Necessario per ESP32 se non si usano certificati specifici

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi connesso!");
}

void loop() {
  if (digitalRead(pinTasto) == LOW) {
    int tavolo = random(1, 21); // Genera un tavolo a caso da 1 a 20
    String messaggio = "🛎️ L'ordine del tavolo " + String(tavolo) + " è pronto!";
    
    if (bot.sendMessage(chatID, messaggio, "")) {
      Serial.println("Messaggio inviato!");
      // Inviamo anche un comando "nascosto" che il secondo ESP32 leggerà
      bot.sendMessage(chatID, "/ATTIVA_BUZZER", ""); 
    }
    
    delay(2000); // Evita invii multipli per una sola pressione
  }
}
